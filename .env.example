# Copy this file to .env and fill in your values.
# .env is gitignored; .env.example is committed as documentation.

# --- AI enrichment (optional) ---------------------------------------------
# Without a key, LogScope works fully; the cluster-summary pane just shows
# "unavailable". With a key, press ctrl+s in the TUI to summarize a cluster.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# --- Defaults (optional) ---------------------------------------------------
# Path to the SQLite index used by `tail`/`search`/`serve`.
LOGSCOPE_DB=logscope.db
